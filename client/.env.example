# Frontend Environment Variables
# Copy this file to .env in the client folder
# This tells React where your backend API is located

# ==========================================
# API ENDPOINT URL
# ==========================================
# The backend server URL where API calls go
# 
# Local Development: http://localhost:5000/api
# Example Production: https://your-project.railway.app/api
#
# This is used by Vite during build AND runtime
# Must start with http:// or https://
VITE_API_URL=http://localhost:5000/api

# ==========================================
# IMPORTANT NOTES
# ==========================================
# 1. If this is blank/wrong, frontend API calls will fail
# 2. When deployed to Vercel, set via Environment Variables dashboard
# 3. Must NOT have trailing slash
# 4. Local dev = http://localhost:5000/api
# 5. Production = https://your-railway-backend.railway.app/api
#
# ==========================================
# TESTING
# ==========================================
# After setting this .env file:
# 1. Run: npm run dev
# 2. Open: http://localhost:5175
# 3. Try to sign up or login
# 4. Check browser console (F12) for errors
#
# If you see CORS error:
# - Backend URL is wrong
# - Backend isn't running
# - Backend hasn't started serving from this URL yet
