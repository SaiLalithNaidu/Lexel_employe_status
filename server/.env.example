# DEPLOYMENT GUIDE - DO NOT COMMIT TO GIT!
# Copy this file to .env in the server folder
# Replace all PLACEHOLDER values with your actual credentials

# Server Port
PORT=5000

# Environment (change to 'production' when deploying)
NODE_ENV=development

# ==========================================
# MONGODB CONNECTION
# ==========================================
# Get this from MongoDB Atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/database-name?retryWrites=true&w=majority
# 
# Example:
# MONGODB_URI=mongodb+srv://lexeluser:XkP9@mN2$qL7vW@cluster0.abc123.mongodb.net/lexel-db?retryWrites=true&w=majority
#
# IMPORTANT: Replace PASSWORD with your actual MongoDB password!
MONGODB_URI=mongodb+srv://YOUR_MONGODB_USERNAME:YOUR_MONGODB_PASSWORD@cluster0.xxxxx.mongodb.net/lexel-db?retryWrites=true&w=majority

# ==========================================
# JWT SECRET
# ==========================================
# Used for signing JWT tokens
# Requirements:
# - Minimum 32 characters long
# - Use random mix of upper/lowercase, numbers, symbols
# - Keep it secret!
# 
# Generate a strong one here: https://www.random.org/strings/
# Example: aB3$xK9@mL2!vQ7%pW1^nR4&sT6*yU8#Z
JWT_SECRET=GENERATE_RANDOM_STRING_MIN_32_CHARS_HERE

# ==========================================
# CORS ORIGIN (Optional - for future scaling)
# ==========================================
# Allow requests from specific domain
# When deployed, set this to your frontend URL
# Example: CORS_ORIGIN=https://your-app.vercel.app
CORS_ORIGIN=http://localhost:5173

# ==========================================
# ADMIN EMAIL (Optional)
# ==========================================
# Email used for first admin account
# Only used during initial setup
ADMIN_EMAIL=admin@lexel.com

# ==========================================
# TESTING NOTES
# ==========================================
# After adding this .env file:
# 1. Run: npm install
# 2. Run: npm start
# 3. Should see: "MongoDB connected: ..."
# 4. Should see: "Server running on port 5000"
#
# If errors:
# - Check MongoDB connection string format
# - Check password is correct (no special chars need escaping in this format)
# - Verify MongoDB user exists in Atlas
# - Verify IP whitelist in MongoDB Atlas
